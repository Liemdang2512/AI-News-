GEMINI_API_KEY=your_google_gemini_api_key_here
# Model REST: https://ai.google.dev/gemini-api/docs/models (ví dụ: gemini-2.0-flash, gemini-2.5-flash)
GEMINI_MODEL=gemini-2.0-flash
# Thời gian chờ mỗi lần gọi Gemini (giây)
GEMINI_REQUEST_TIMEOUT=120
FRONTEND_URL=http://localhost:3000

# Backend network binding configuration
# Default host (0.0.0.0) keeps the service accessible from other machines /
# containers, matching the original behaviour before BACKEND_HOST was added.
# For desktop/Electron builds that only need local access, you can override to:
#   BACKEND_HOST=127.0.0.1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
