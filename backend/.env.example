GEMINI_API_KEY=your_google_gemini_api_key_here
# Model REST: https://ai.google.dev/gemini-api/docs/models (ví dụ: gemini-2.0-flash, gemini-2.5-flash)
GEMINI_MODEL=gemini-2.0-flash
# Thời gian chờ mỗi lần gọi Gemini (giây)
GEMINI_REQUEST_TIMEOUT=120
# Frontend origin(s) allowed for CORS (cookie credentials).
# You can set multiple origins separated by commas:
#   FRONTEND_URL=http://localhost:3000,http://localhost:3002
FRONTEND_URL=http://localhost:3000

# Backend network binding configuration
# Default host (0.0.0.0) keeps the service accessible from other machines /
# containers, matching the original behaviour before BACKEND_HOST was added.
# For desktop/Electron builds that only need local access, you can override to:
#   BACKEND_HOST=127.0.0.1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# DB logging (Postgres recommended, hosted on Railway)
# Set LOG_DB_ENABLED=true to enable writing request/error logs to DB.
LOG_DB_ENABLED=false
# Example DSN format (fill in your Railway values):
# LOG_DB_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
LOG_DB_DSN=

# Local Docker Postgres example (docker-compose.yml at repo root):
# LOG_DB_ENABLED=true
# LOG_DB_DSN=postgresql://app_crwal:app_crwal@127.0.0.1:5432/app_crwal

# ---------------------------------------------------------------------------
# Auth (cookie session)
# ---------------------------------------------------------------------------
# Admin bootstrap (optional for development):
# - ADMIN_PASSWORD_HASH must be a bcrypt/passlib compatible hash.
#   For example (Python):
#     from passlib.hash import bcrypt; bcrypt.hash("admin-pass")
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# Session store: "memory" (dev/tests) or "postgres" (asyncpg).
AUTH_SESSION_STORAGE=memory
# Optional dedicated DSN for auth tables. If empty, auth can reuse LOG_DB_DSN.
# AUTH_DB_DSN=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
AUTH_DB_DSN=
AUTH_SESSION_TTL_SEC=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_SESSION_COOKIE_NAME=session_id
